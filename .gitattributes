# Normalize text files and keep Linux/runtime-critical files with LF endings.
* text=auto

*.py text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.service text eol=lf
*.template text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.mmd text eol=lf
*.svg text eol=lf
*.html text eol=lf

# Binary / archive files.
*.zip binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary